DATABASE_URL=postgresql://user:password@localhost:5433/capacitor

# LLM Provider — set ONE API key (auto-detected)
# GOOGLE_GENERATIVE_AI_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
# MOONSHOT_API_KEY=your-key-here

# Optional: force provider or model (auto-detected if omitted)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# Langfuse GenAI observability (pre-configured in docker-compose, no changes needed)
# LANGFUSE_PUBLIC_KEY=pk-cap-local
# LANGFUSE_SECRET_KEY=sk-cap-local
# LANGFUSE_BASEURL=http://langfuse:3000

# Logging
# LOG_LEVEL=info
